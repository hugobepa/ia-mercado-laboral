---
import Hero from "../components/sections/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "IA y Mercado Laboral en Catalunya";
const pageDescription =
  "Landing reutilizable con secciones Hero, Datos y Provincias para visualizar el impacto de la IA en Catalunya.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Hero />

  <Fragment slot="footer">
    <p class="text-sm text-[var(--color-text-light)]">
      Datos de referencia: Randstad + Idescat. Landing mobile-first con foco accesible y enlaces seguros para subruta.
    </p>
  </Fragment>
</BaseLayout>
