---
import Navigation from "../components/ui/Navigation.astro";
import {
  getCurrentPath,
  normalizeBasePath,
  resolveInternalHref,
  type NavItem,
} from "../utils/navigation-path";
import htmxScriptUrl from "htmx.org/dist/htmx.min.js?url";

interface Props {
  title: string;
  description?: string;
  nav?: NavItem[];
  showNavigation?: boolean;
}

const {
  title,
  description = "IA y Mercado Laboral",
  nav,
  showNavigation = true,
} = Astro.props as Props;

const basePath = normalizeBasePath(import.meta.env.BASE_URL);
const currentPath = getCurrentPath(Astro.url.pathname, basePath);

const defaultNav: NavItem[] = [
  { label: "Inicio", href: "/" },
  { label: "Datos", href: "/#datos" },
  { label: "Graficos", href: "/#graficos" },
  { label: "Fuentes", href: "/#fuentes" },
];

const navItems = (nav ?? defaultNav).map((item) => ({
  ...item,
  href: resolveInternalHref(item.href, basePath),
}));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script defer src={htmxScriptUrl}></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    {showNavigation && (
      <Navigation items={navItems} currentPath={currentPath} basePath={basePath} />
    )}

    <main id="main-content" class:list={["min-h-screen", showNavigation && "pt-20"]}>
      <slot />
    </main>

    <footer class="hidden border-t border-[var(--color-neutral-dark)] py-6 md:block">
      <div class="page-shell py-0">
        <slot name="footer" />
      </div>
    </footer>

    <button
      id="back-to-top"
      type="button"
      aria-label="Volver arriba"
      class="focus-ring touch-target fixed bottom-6 right-4 z-40 rounded-full bg-[var(--color-primary)] px-3 text-[var(--color-neutral)] opacity-0 shadow-sm transition-all duration-200 hover:shadow-md md:hidden"
    >
      ↑
    </button>

    <script>
      const backBtn = document.getElementById("back-to-top");

      if (backBtn) {
        const onScroll = () => {
          if (window.scrollY > 300) {
            backBtn.classList.remove("opacity-0", "pointer-events-none");
            backBtn.classList.add("opacity-100");
          } else {
            backBtn.classList.add("opacity-0", "pointer-events-none");
            backBtn.classList.remove("opacity-100");
          }
        };

        window.addEventListener("scroll", onScroll, { passive: true });
        backBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>