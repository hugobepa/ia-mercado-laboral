---
import BarChart from "../charts/BarChart.astro";
import DonutChart from "../charts/DonutChart.astro";
import LineChart from "../charts/LineChart.astro";
import chartsConfig from "../../data/charts-config.json";

const currentPath = Astro.url.pathname;
---

<section id="graficos" class="space-y-5 py-8" aria-labelledby="graficos-title">
  <header class="space-y-2">
    <p class="text-sm font-semibold uppercase tracking-wide text-[var(--color-secondary)]">ApexCharts Reutilizables</p>
    <h2 id="graficos-title" class="font-bold text-[var(--color-text)]">Graficas interactivas con datos internos</h2>
    <p class="max-w-3xl text-sm text-[var(--color-text-light)]">
      Las tres visualizaciones comparten paleta, tipografia, tooltip, leyenda y carga diferida.
      Si faltan datos se muestra estado vacio con CTA de recuperacion.
    </p>
  </header>

  <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
    <BarChart
      title="Sectores con empleo en riesgo"
      ariaLabel="Grafica de barras de empleo en riesgo por sector"
      config={chartsConfig.barChart}
      currentPath={currentPath}
    />

    <DonutChart
      title="Distribucion del impacto IA"
      ariaLabel="Grafica donut de distribucion del impacto IA"
      config={chartsConfig.donutChart}
      currentPath={currentPath}
    />

    <div class="lg:col-span-2">
      <LineChart
        title="Tendencia proyectada 2023-2033"
        ariaLabel="Grafica de lineas con evolucion anual de transformacion IA entre 2023 y 2033"
        config={chartsConfig.lineChart}
        currentPath={currentPath}
      />
    </div>
  </div>
</section>
