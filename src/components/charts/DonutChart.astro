---
import chartsConfig from "../../data/charts-config.json";
import { buildDonutOptions, getRouteSafeCtaHref } from "../../utils/chart-helpers.js";

interface Props {
  title?: string;
  ariaLabel?: string;
  config?: typeof chartsConfig.donutChart;
  currentPath?: string;
  ctaLabel?: string;
}

const {
  title = "Distribucion del impacto IA",
  ariaLabel = "Grafica donut de distribucion del impacto IA",
  config = chartsConfig.donutChart,
  currentPath = Astro.url.pathname,
  ctaLabel = "Volver a filtros",
} = Astro.props as Props;

const chartId = `donut-chart-${Math.random().toString(36).slice(2, 9)}`;
const safeHref = getRouteSafeCtaHref(currentPath, "datos");
const options = buildDonutOptions(config, title, ariaLabel);
const serialized = options ? JSON.stringify(options) : "";
---

<section class="surface-card p-4" aria-label={ariaLabel}>
  {options ? (
    <div
      id={chartId}
      data-chart-id={chartId}
      data-chart-type="apex"
      data-chart-lazy="true"
      data-apex-config={serialized}
      class="chart-host"
      role="img"
      aria-label={ariaLabel}
    />
  ) : (
    <div class="rounded-lg border border-[var(--color-neutral-dark)] bg-white p-4" aria-live="polite">
      <p class="text-sm font-medium text-[var(--color-text)]">No se pudo cargar la grafica donut.</p>
      <p class="mt-1 text-sm text-[var(--color-text-light)]">Configura datos validos o vuelve a filtros.</p>
      <div class="mt-3 flex gap-2">
        <a class="focus-ring rounded bg-[var(--color-primary)] px-3 py-2 text-sm text-white" href={safeHref}>{ctaLabel}</a>
        <a class="focus-ring rounded border border-[var(--color-neutral-dark)] px-3 py-2 text-sm" href={currentPath}>Recargar</a>
      </div>
    </div>
  )}
</section>

<style>
  .chart-host {
    min-height: 300px;
  }

  @media (min-width: 768px) {
    .chart-host {
      min-height: 350px;
    }
  }
</style>
