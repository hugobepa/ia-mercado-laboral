    @apply absolute inset-4 flex justify-around items-center;
  }

  .skeleton-point {
    @apply w-2 h-2 bg-gray-400 rounded-full;
    animation: point-pulse 1.5s ease-in-out infinite;
  }

  .skeleton-point:nth-child(1) { animation-delay: 0.1s; }
  .skeleton-point:nth-child(2) { animation-delay: 0.2s; }
  .skeleton-point:nth-child(3) { animation-delay: 0.3s; }
  .skeleton-point:nth-child(4) { animation-delay: 0.4s; }
  .skeleton-point:nth-child(5) { animation-delay: 0.5s; }

  /* Card Skeletons */
  .skeleton-card-content {
    @apply h-full flex flex-col items-center justify-center space-y-4;
  }

  .skeleton-card-icon {
    @apply skeleton-animated w-12 h-12 rounded-full;
  }

  .skeleton-card-value {
    @apply skeleton-animated h-8 w-24 rounded;
  }

  .skeleton-card-label {
    @apply skeleton-animated h-4 w-20 rounded;
  }

  .skeleton-card-change {
    @apply skeleton-animated h-3 w-16 rounded;
  }

