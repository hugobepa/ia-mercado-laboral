  .skeleton-stats-grid {
    @apply h-full grid grid-cols-1 md:grid-cols-3 gap-4;
  }

  .skeleton-stat-item {
    @apply flex flex-col space-y-3 p-4 bg-white rounded border;
  }

  .skeleton-stat-value {
    @apply skeleton-animated h-10 w-full rounded;
  }

  .skeleton-stat-label {
    @apply skeleton-animated h-4 w-3/4 rounded;
  }

  /* Legend Skeletons */
  .skeleton-legend {
    @apply mt-4 flex flex-wrap gap-4;
  }

  .skeleton-legend-item {
    @apply flex items-center gap-2;
  }

  .skeleton-legend-indicator {
    @apply skeleton-animated w-4 h-4 rounded-full;
  }

  .skeleton-legend-label {
    @apply skeleton-animated h-4 w-16 rounded;
  }

  /* Spinner for reduced motion */
  .skeleton-spinner {
    @apply absolute bottom-4 right-4 flex gap-1;
    @apply opacity-0;
  }

  @media (prefers-reduced-motion: reduce) {
    .skeleton-animated {
      @apply animate-none;
    }
    
    .skeleton-animated::before {
      @apply hidden;
    }

    .skeleton-spinner {
      @apply opacity-100;
    }

    .spinner-dot {
      @apply w-2 h-2 bg-gray-400 rounded-full;
      animation: fade 1.4s ease-in-out infinite both;
    }

    .spinner-dot:nth-child(1) { animation-delay: -0.32s; }
    .spinner-dot:nth-child(2) { animation-delay: -0.16s; }
    .spinner-dot:nth-child(3) { animation-delay: 0s; }
  }

  /* Animations */
  @keyframes skeleton {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes line-draw {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  @keyframes point-pulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.2); opacity: 1; }
  }

  @keyframes fade {
    0%, 39%, 100% { opacity: 0; }
    40% { opacity: 1; }
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    .chart-skeleton {
      @apply bg-gray-800 border-gray-700;
    }

    .skeleton-animated {
      @apply bg-gradient-to-r from-gray-700 via-gray-600 to-gray-700;
    }

    .skeleton-donut-circle {
      @apply border-gray-600 border-l-gray-500;
    }

    .skeleton-donut-inner {
      @apply border-gray-600;
    }

    .skeleton-line-path {
      @apply border-gray-600;
    }

    .skeleton-line-path::after {
      background: linear-gradient(90deg, #4b5563 0%, #6b7280 25%, #4b5563 50%, #6b7280 75%, #4b5563 100%);
    }

    .skeleton-point {
      @apply bg-gray-500;
    }

    .skeleton-stat-item {
      @apply bg-gray-800 border-gray-700;
    }

    .spinner-dot {
      @apply bg-gray-500;
    }
  }

  /* High contrast mode */
  @media (prefers-contrast: high) {
    .chart-skeleton {
      @apply border-2 border-black;
    }

    .skeleton-animated {
      @apply bg-gray-400;
    }

    .skeleton-donut-circle {
      @apply border-black;
    }
  }

  /* Utilities */
  .bg-size-200 {
    background-size: 200% 100%;
  }

  .animate-skeleton {
    animation: skeleton 1.5s ease-in-out infinite;
  }

  .sr-only {
    @apply absolute w-px h-px p-0 -m-px overflow-hidden whitespace-nowrap border-0;
  }
</style>

<script>
  // Auto-remove skeleton when real content loads
  if (typeof window !== 'undefined') {
    // Observer to detect when skeleton should be removed
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        mutation.addedNodes.forEach((node) => {
          if (node.nodeType === 1 && (node as Element).matches('[data-chart], .chart-loaded')) {
            // Real chart content detected, remove skeleton
            const skeleton = node.parentElement?.querySelector('.chart-skeleton') as HTMLElement;
            if (skeleton) {
              skeleton.style.opacity = '0';
              setTimeout(() => skeleton.remove(), 300);
            }
          }
        });
      });
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });

    // Also listen for HTMX events
    document.addEventListener('htmx:afterSettle', (event) => {
      const target = event.target as Element;
      if (target) {
        const skeletons = target.querySelectorAll('.chart-skeleton');
        skeletons.forEach((skeleton: Element) => {
          if (target.querySelector('[data-chart], .chart-loaded')) {
            const skeletonElement = skeleton as HTMLElement;
            skeletonElement.style.opacity = '0';
            setTimeout(() => skeleton.remove(), 300);
          }
        });
      }
    });
  }
</script>