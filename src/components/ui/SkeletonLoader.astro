  .skeleton-line-chart {
    @apply h-full flex flex-col;
  }

  .skeleton-line-container {
    @apply flex-1 relative;
  }

  .skeleton-line-path {
    @apply absolute inset-4 border-b-2 border-r-2 border-gray-300 rounded-br;
  }

  .skeleton-line-path::after {
    content: '';
    @apply absolute top-1/2 left-0 right-0 h-0.5 bg-gray-300 rounded;
    background: linear-gradient(90deg, #d1d5db 0%, #9ca3af 25%, #d1d5db 50%, #9ca3af 75%, #d1d5db 100%);
