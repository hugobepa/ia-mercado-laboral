---
// Skeleton Loader Component for Charts - Tailwind 4.x Compatible
interface Props {
  type?: "bar" | "donut" | "line" | "card";
  height?: string;
  className?: string;
}

const {
  type = "bar",
  height = "320px",
  className = ""
} = Astro.props;
---

<div 
  class={`chart-skeleton-tw4 ${className}`}
  role="status"
  aria-label="Cargando gráfica..."
  style={`height: ${height};`}
>
  <div class="skeleton-content-tw4">
    <!-- Simple skeleton bars for any type -->
    <div class="skeleton-bars-tw4">
      <div class="skeleton-bar-tw4"></div>
      <div class="skeleton-bar-tw4"></div>
      <div class="skeleton-bar-tw4"></div>
      <div class="skeleton-bar-tw4"></div>
    </div>
  </div>
</div>

<style>
  .chart-skeleton-tw4 {
    position: relative;
    background-color: #f9fafb;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .skeleton-content-tw4 {
    flex: 1;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .skeleton-bars-tw4 {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    height: 200px;
  }

  .skeleton-bar-tw4 {
    width: 2rem;
    background: linear-gradient(45deg, #e5e7eb, #d1d5db);
    border-radius: 0.25rem;
    animation: skeleton-pulse 2s ease-in-out infinite;
  }

  .skeleton-bar-tw4:nth-child(1) { height: 60%; animation-delay: 0s; }
  .skeleton-bar-tw4:nth-child(2) { height: 80%; animation-delay: 0.2s; }
  .skeleton-bar-tw4:nth-child(3) { height: 45%; animation-delay: 0.4s; }
  .skeleton-bar-tw4:nth-child(4) { height: 70%; animation-delay: 0.6s; }

  @keyframes skeleton-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
</style>---
// Skeleton Loader Component for Charts
// Provides accessible loading states with proper animations
interface Props {
  type?: "bar" | "donut" | "line" | "card" | "stats";
  height?: string;
  width?: string;
  showTitle?: boolean;
  showLegend?: boolean;
  className?: string;
  ariaLabel?: string;
}

const {
  type = "bar",
  height = "320px",
  width = "100%",
  showTitle = true,
  showLegend = true,
  className = "",
  ariaLabel = "Cargando gráfica..."
} = Astro.props;

const skeletonId = `skeleton-${Math.random().toString(36).substr(2, 9)}`;
---

<div 
  class={`chart-skeleton ${className}`}
  role="status"
  aria-label={ariaLabel}
  aria-live="polite"
  style={`height: ${height}; width: ${width};`}
  data-skeleton-type={type}
  id={skeletonId}
>
  <!-- Screen reader announcement -->
  <span class="sr-only">{ariaLabel}</span>

  <!-- Skeleton Content -->
  <div class="skeleton-container">
    
    <!-- Title Skeleton -->
    {showTitle && (
      <div class="skeleton-header">
        <div class="skeleton-title skeleton-anim"></div>
        <div class="skeleton-subtitle skeleton-anim"></div>
      </div>
    )}

    <!-- Main Chart Area -->
    <div class="skeleton-chart">
      
      {type === "bar" && (
        <div class="skeleton-bar-chart">
          <div class="skeleton-axes">
            <div class="skeleton-y-axis">
              <div class="skeleton-axis-label skeleton-anim"></div>
              <div class="skeleton-axis-label skeleton-anim"></div>
              <div class="skeleton-axis-label skeleton-anim"></div>
              <div class="skeleton-axis-label skeleton-anim"></div>
              <div class="skeleton-axis-label skeleton-anim"></div>
            </div>
            <div class="skeleton-bars-container">
              <div class="skeleton-bar skeleton-anim" style="height: 60%;"></div>
              <div class="skeleton-bar skeleton-anim" style="height: 80%;"></div>
              <div class="skeleton-bar skeleton-anim" style="height: 45%;"></div>
              <div class="skeleton-bar skeleton-anim" style="height: 70%;"></div>
              <div class="skeleton-bar skeleton-anim" style="height: 55%;"></div>
            </div>
          </div>
        </div>
      )}
      
      {type === "donut" && (
        <div class="skeleton-donut-chart">
          <div class="skeleton-chart-area">
            <div class="skeleton-donut">
              <div class="skeleton-donut-inner"></div>
            </div>
          </div>
        </div>
      )}
      
      {type === "line" && (
        <div class="skeleton-line-chart">
          <div class="skeleton-chart-area">
            <div class="skeleton-line-axes"></div>
            <div class="skeleton-line-path"></div>
            <div class="skeleton-line-points">
              <div class="skeleton-point"></div>
              <div class="skeleton-point"></div>
              <div class="skeleton-point"></div>
              <div class="skeleton-point"></div>
              <div class="skeleton-point"></div>
              <div class="skeleton-point"></div>
            </div>
          </div>
        </div>
      )}
      
      {type === "card" && (
        <div class="skeleton-card-chart">
          <div class="skeleton-icon skeleton-anim"></div>
          <div class="skeleton-value skeleton-anim"></div>
          <div class="skeleton-label skeleton-anim"></div>
          <div class="skeleton-change skeleton-anim"></div>
        </div>
      )}
      
      {type === "stats" && (
        <div class="skeleton-stats-chart">
          <div class="skeleton-stat">
            <div class="skeleton-stat-value skeleton-anim"></div>
            <div class="skeleton-stat-label skeleton-anim"></div>
          </div>
          <div class="skeleton-stat">
            <div class="skeleton-stat-value skeleton-anim"></div>
            <div class="skeleton-stat-label skeleton-anim"></div>
          </div>
          <div class="skeleton-stat">
            <div class="skeleton-stat-value skeleton-anim"></div>
            <div class="skeleton-stat-label skeleton-anim"></div>
          </div>
        </div>
      )}
    </div>

  </div>
</div>

<style>
  .chart-skeleton {
    position: relative;
    background-color: #f9fafb;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .skeleton-container {
    flex: 1;
    padding: 1rem;
  }
  
  @media (min-width: 768px) {
    .skeleton-container {
      padding: 1.5rem;
    }
  }

  /* Base skeleton animation */
  .skeleton-animated {
    background-image: linear-gradient(to right, #e5e7eb, #d1d5db, #e5e7eb);
    background-size: 200% 100%;
    animation: skeleton 2s ease-in-out infinite;
    border-radius: 4px;
  }

  /* Header Skeletons */
  .skeleton-header {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skeleton-title {
    height: 1.5rem;
    width: 12rem;
    border-radius: 0.25rem;
  }

  .skeleton-subtitle {
    height: 1rem;
    width: 8rem;
    border-radius: 0.25rem;
  }

  /* Chart Skeletons */
  .skeleton-chart {
    flex: 1;
    position: relative;
  }

  /* Bar Chart */
  .skeleton-bar-chart {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .skeleton-axes {
    flex: 1;
    display: flex;
  }

  .skeleton-y-axis {
    width: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.5rem 0;
  }

  .skeleton-y-axis .skeleton-axis-label {
    height: 0.75rem;
    width: 100%;
    border-radius: 0.25rem;
  }

  .skeleton-bars-container {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    padding: 0 1rem 0.5rem;
  }

  .skeleton-bar {
    width: 2rem;
    border-radius: 4px 4px 0 0;
  }

  @media (min-width: 768px) {
    .skeleton-bar {
      width: 3rem;
    }
  }

  /* Donut Chart */
  .skeleton-donut-chart {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .skeleton-chart-area {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .skeleton-donut {
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    border: 8px solid #d1d5db;
    border-left-color: #e5e7eb;
    animation: spin 1s linear infinite;
  }

  .skeleton-donut-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 8px solid #e5e7eb;
  }

  /* Line Chart */
  .skeleton-line-chart {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .skeleton-line-axes {
    position: absolute;
    inset: 1rem;
    border-bottom: 2px solid #d1d5db;
    border-right: 2px solid #d1d5db;
    border-bottom-right-radius: 0.25rem;
  }

  .skeleton-line-path {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background-color: #d1d5db;
    border-radius: 0.25rem;
  }

  .skeleton-line-points {
    position: absolute;
    inset: 1rem;
    display: flex;
    justify-content: space-around;
    align-items: center;
  }

  .skeleton-point {
    width: 0.5rem;
    height: 0.5rem;
    background-color: #9ca3af;
    border-radius: 50%;
  }

  /* Card Chart */
  .skeleton-card-chart {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .skeleton-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
  }

  .skeleton-value {
    height: 2rem;
    width: 6rem;
    border-radius: 0.25rem;
  }

  .skeleton-label {
    height: 1rem;
    width: 5rem;
    border-radius: 0.25rem;
  }

  .skeleton-change {
    height: 0.75rem;
    width: 4rem;
    border-radius: 0.25rem;
  }

  /* Stats Chart */
  .skeleton-stats-chart {
    height: 100%;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 1rem;
  }

  .skeleton-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .skeleton-stat-value {
    height: 1.5rem;
    width: 4rem;
    border-radius: 0.25rem;
  }

  .skeleton-stat-label {
    height: 0.875rem;
    width: 3rem;
    border-radius: 0.25rem;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Animations */
  @keyframes skeleton {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }
</style>---
// Skeleton Loader Component for Charts
// Provides accessible loading states with proper animations
interface Props {
  type?: "bar" | "donut" | "line" | "card" | "stats";
  height?: string;
  width?: string;
  showTitle?: boolean;
  showLegend?: boolean;
  className?: string;
  ariaLabel?: string;
}

const {
  type = "bar",
  height = "320px",
  width = "100%",
  showTitle = true,
  showLegend = true,
  className = "",
  ariaLabel = "Cargando gráfica..."
} = Astro.props;

const skeletonId = `skeleton-${Math.random().toString(36).substr(2, 9)}`;
---

<div 
  class={`chart-skeleton ${className}`}
  role="status"
  aria-label={ariaLabel}
  aria-live="polite"
  style={`height: ${height}; width: ${width};`}
  data-skeleton-type={type}
  id={skeletonId}
>
  <!-- Screen reader announcement -->
  <span class="sr-only">{ariaLabel}</span>

  <!-- Skeleton Content -->
  <div class="skeleton-container">
    
    <!-- Title Skeleton -->
    {showTitle && (
      <div class="skeleton-header">
        <div class="skeleton-title"></div>
        <div class="skeleton-subtitle"></div>
      </div>
    )}

    <!-- Main Chart Area -->
    <div class="skeleton-chart">
      {type === "bar" && (
        <div class="skeleton-bar-chart">
          <div class="skeleton-axes">
            <!-- Y-axis labels -->
            <div class="skeleton-y-axis">
              <div class="skeleton-axis-label"></div>
              <div class="skeleton-axis-label"></div>
              <div class="skeleton-axis-label"></div>
              <div class="skeleton-axis-label"></div>
            </div>
            <!-- Chart bars -->
            <div class="skeleton-bars-container">
              <div class="skeleton-bar" style="height: 75%;"></div>
              <div class="skeleton-bar" style="height: 45%;"></div>
              <div class="skeleton-bar" style="height: 90%;"></div>
              <div class="skeleton-bar" style="height: 60%;"></div>
              <div class="skeleton-bar" style="height: 80%;"></div>
            </div>
          </div>
          <!-- X-axis labels -->
          <div class="skeleton-x-axis">
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
          </div>
        </div>
      )}

      {type === "donut" && (
        <div class="skeleton-donut-chart">
          <div class="skeleton-donut-circle">
            <div class="skeleton-donut-inner"></div>
          </div>
          <div class="skeleton-donut-center">
            <div class="skeleton-center-value"></div>
            <div class="skeleton-center-label"></div>
          </div>
        </div>
      )}

      {type === "line" && (
        <div class="skeleton-line-chart">
          <div class="skeleton-axes">
            <!-- Y-axis -->
            <div class="skeleton-y-axis">
              <div class="skeleton-axis-label"></div>
              <div class="skeleton-axis-label"></div>
              <div class="skeleton-axis-label"></div>
              <div class="skeleton-axis-label"></div>
            </div>
            <!-- Line path -->
            <div class="skeleton-line-container">
              <div class="skeleton-line-path"></div>
              <div class="skeleton-data-points">
                <div class="skeleton-point"></div>
                <div class="skeleton-point"></div>
                <div class="skeleton-point"></div>
                <div class="skeleton-point"></div>
                <div class="skeleton-point"></div>
              </div>
            </div>
          </div>
          <!-- X-axis -->
          <div class="skeleton-x-axis">
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
            <div class="skeleton-axis-label"></div>
          </div>
        </div>
      )}

      {type === "card" && (
        <div class="skeleton-card-content">
          <div class="skeleton-card-icon"></div>
          <div class="skeleton-card-value"></div>
          <div class="skeleton-card-label"></div>
          <div class="skeleton-card-change"></div>
        </div>
      )}

      {type === "stats" && (
        <div class="skeleton-stats-grid">
          <div class="skeleton-stat-item">
            <div class="skeleton-stat-value"></div>
            <div class="skeleton-stat-label"></div>
          </div>
          <div class="skeleton-stat-item">
            <div class="skeleton-stat-value"></div>
            <div class="skeleton-stat-label"></div>
          </div>
          <div class="skeleton-stat-item">
            <div class="skeleton-stat-value"></div>
            <div class="skeleton-stat-label"></div>
          </div>
        </div>
      )}
    </div>

    <!-- Legend Skeleton -->
    {showLegend && type !== "card" && type !== "stats" && (
      <div class="skeleton-legend">
        <div class="skeleton-legend-item">
          <div class="skeleton-legend-indicator"></div>
          <div class="skeleton-legend-label"></div>
        </div>
        <div class="skeleton-legend-item">
          <div class="skeleton-legend-indicator"></div>
          <div class="skeleton-legend-label"></div>
        </div>
        <div class="skeleton-legend-item">
          <div class="skeleton-legend-indicator"></div>
          <div class="skeleton-legend-label"></div>
        </div>
      </div>
