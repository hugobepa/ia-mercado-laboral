  </div>

  <!-- Loading indicator for reduced motion -->
  <div class="skeleton-spinner" aria-hidden="true">
    <div class="spinner-dot"></div>
    <div class="spinner-dot"></div>
    <div class="spinner-dot"></div>
  </div>
</div>

<style>
  .chart-skeleton {
    position: relative;
    background-color: #f9fafb;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .skeleton-container {
    flex: 1;
    padding: 1rem;
  }
  
  @media (min-width: 768px) {
    .skeleton-container {
      padding: 1.5rem;
    }
  }

  /* Base skeleton animation */
  .skeleton-animated {
    background-image: linear-gradient(to right, #e5e7eb, #d1d5db, #e5e7eb);
    background-size: 200% 100%;
    animation: skeleton 2s ease-in-out infinite;
    border-radius: 4px;
  }

  .skeleton-animated::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background-image: linear-gradient(to right, transparent, white, transparent);
    opacity: 0.6;
    animation: shimmer 1.5s ease-in-out infinite;
  }

  /* Header Skeletons */
  .skeleton-header {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skeleton-title {
    height: 1.5rem;
    width: 12rem;
    border-radius: 0.25rem;
  }

  .skeleton-subtitle {
    height: 1rem;
    width: 8rem;
    border-radius: 0.25rem;
  }

  /* Chart Skeletons */
  .skeleton-chart {
    flex: 1;
    position: relative;
  }

  /* Bar Chart Skeletons */
  .skeleton-bar-chart {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .skeleton-axes {
    flex: 1;
    display: flex;
  }

  .skeleton-y-axis {
    width: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .skeleton-y-axis .skeleton-axis-label {
    height: 0.75rem;
    width: 100%;
    border-radius: 0.25rem;
  }

  .skeleton-bars-container {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    padding-left: 1rem;
    padding-right: 1rem;
    padding-bottom: 0.5rem;
  }

  .skeleton-bar {
    @apply skeleton-animated w-8 md:w-12 rounded-t;
    min-height: 20px;
  }

  .skeleton-x-axis {
    @apply flex justify-around px-12 pt-2;
  }

  .skeleton-x-axis .skeleton-axis-label {
    @apply skeleton-animated h-3 w-16 rounded;
  }

  /* Donut Chart Skeletons */
  .skeleton-donut-chart {
    @apply relative flex items-center justify-center h-full;
  }

  .skeleton-donut-circle {
    @apply w-48 h-48 rounded-full border-8;
    @apply border-gray-300 border-l-gray-200;
    animation: spin 2s linear infinite;
  }

  .skeleton-donut-inner {
    @apply w-full h-full rounded-full border-8 border-gray-200;
  }

  .skeleton-donut-center {
    @apply absolute inset-0 flex flex-col items-center justify-center space-y-2;
  }

  .skeleton-center-value {
    @apply skeleton-animated h-8 w-16 rounded;
  }

  .skeleton-center-label {
    @apply skeleton-animated h-4 w-12 rounded;
  }

